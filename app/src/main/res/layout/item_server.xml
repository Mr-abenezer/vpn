<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    style="@style/CardStyle">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/server_flag"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_flag_default"
            android:contentDescription="Flag"
            android:background="@drawable/circle_background"
            android:padding="6dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/server_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Server Name"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">

                <TextView
                    android:id="@+id/server_carrier"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Carrier"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />

                <View
                    android:layout_width="4dp"
                    android:layout_height="4dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/circle_dot"
                    android:layout_gravity="center_vertical" />

                <TextView
                    android:id="@+id/protocol_indicator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="V2RAY"
                    android:textColor="@color/accent"
                    android:textSize="11sp"
                    android:background="@drawable/protocol_badge"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp" />

            </LinearLayout>

        </LinearLayout>

        <ImageView
            android:id="@+id/signal_indicator"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_signal_high"
            android:contentDescription="Signal"
            app:tint="@color/connected" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
