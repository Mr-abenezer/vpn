<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Network Permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />

    <!-- Storage Permissions -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="32"
        tools:ignore="ScopedStorage" />

    <!-- VPN & Foreground Service -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!-- Notifications -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- System -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.USE_CREDENTIALS" />
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />

    <!-- Shortcut -->
    <uses-permission android:name="com.android.launcher.permission.INSTALL_SHORTCUT" />

    <!-- Ads & Analytics -->
    <uses-permission android:name="com.google.android.gms.permission.AD_ID" />
    <uses-permission android:name="android.permission.ACCESS_ADSERVICES_AD_ID" />
    <uses-permission android:name="android.permission.ACCESS_ADSERVICES_ATTRIBUTION" />
    <uses-permission android:name="android.permission.ACCESS_ADSERVICES_TOPICS" />
    <uses-permission android:name="com.google.android.finsky.permission.BIND_GET_INSTALL_REFERRER_SERVICE" />
    <uses-permission android:name="com.google.android.providers.gsf.permission.READ_GSERVICES" />

    <uses-feature android:name="android.hardware.touchscreen" android:required="false" />

    <application
        android:name=".VPNApplication"
        android:allowBackup="true"
        android:icon="@drawable/ic_app_icon"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_app_icon"
        android:supportsRtl="true"
        android:theme="@style/AppTheme"
        android:networkSecurityConfig="@xml/network_security_config"
        android:usesCleartextTraffic="true"
        tools:targetApi="34">

        <!-- AdMob Application ID -->
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="ca-app-pub-3940256099942544~3347511713" />

        <property
            android:name="android.adservices.AD_SERVICES_CONFIG"
            android:resource="@xml/gma_ad_services_config"
            tools:replace="android:resource" />

        <provider
            android:name="com.google.android.gms.ads.MobileAdsInitProvider"
            android:authorities="${applicationId}.mobileadsinitprovider"
            tools:node="remove" />

        <!-- Splash Activity -->
        <activity
            android:name=".ui.activities.SplashActivity"
            android:exported="true"
            android:theme="@style/SplashTheme">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Main VPN Activity -->
        <activity
            android:name=".ui.activities.VPNClient"
            android:exported="false"
            android:launchMode="singleTop" />

        <!-- About Activity -->
        <activity
            android:name=".ui.activities.AboutActivity"
            android:exported="false"
            android:label="@string/about" />

        <!-- App List / Split Tunnel Activity -->
        <activity
            android:name=".ui.activities.AppListActivity"
            android:exported="false"
            android:label="@string/split_tunnel" />

        <!-- IP Hunter Activity -->
        <activity
            android:name=".ui.activities.IPHunterActivity"
            android:exported="false"
            android:label="@string/ip_hunter" />

        <!-- Import Tweak Activity -->
        <activity
            android:name=".ui.activities.ImportTweakActivity"
            android:exported="false"
            android:label="@string/import_tweak" />

        <!-- VPN Share Activity -->
        <activity
            android:name=".ui.activities.VPNShareActivity"
            android:exported="false"
            android:label="@string/vpn_share" />

        <!-- Exception / Crash Activity -->
        <activity
            android:name=".ui.activities.ExceptionActivity"
            android:exported="false" />

        <!-- Settings Activity -->
        <activity
            android:name=".ui.activities.SettingsActivity"
            android:exported="false"
            android:label="@string/settings" />

        <!-- Server List Activity -->
        <activity
            android:name=".ui.activities.ServerListActivity"
            android:exported="false"
            android:label="@string/servers" />

        <!-- Logs Activity -->
        <activity
            android:name=".ui.activities.LogsActivity"
            android:exported="false"
            android:label="@string/logs" />

        <!-- Stats Activity -->
        <activity
            android:name=".ui.activities.StatsActivity"
            android:exported="false"
            android:label="@string/stats" />

        <!-- Tunnel VPN Service -->
        <service
            android:name=".service.TunnelVpnService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="dataSync"
            android:permission="android.permission.BIND_VPN_SERVICE">
            <intent-filter>
                <action android:name="android.net.VpnService" />
            </intent-filter>
        </service>

        <!-- Psiphon VPN Service -->
        <service
            android:name=".service.PsiphonVpnService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="dataSync"
            android:permission="android.permission.BIND_VPN_SERVICE">
            <intent-filter>
                <action android:name="android.net.VpnService" />
            </intent-filter>
        </service>

        <!-- Firewall Puncher Service -->
        <service
            android:name=".service.FWPuncherService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- DNS Services -->
        <service
            android:name=".service.SocksDNSService"
            android:enabled="true"
            android:exported="false" />

        <service
            android:name=".service.PsiphonDNSService"
            android:enabled="true"
            android:exported="false" />

        <service
            android:name=".service.XRayDNSService"
            android:enabled="true"
            android:exported="false" />

        <!-- Proxy Service -->
        <service
            android:name=".service.ProxyService"
            android:enabled="true"
            android:exported="false" />

        <!-- Broadcast Receivers -->
        <receiver
            android:name=".receiver.MainReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="com.bdnet.vpn.ACTION_SERVICE_STOP" />
                <action android:name="com.bdnet.vpn.ACTION_SERVICE_RESTART" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".receiver.BootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
            </intent-filter>
        </receiver>

    </application>
</manifest>
